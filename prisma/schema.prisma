generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String
  role           Role
  department     String?
  managerId      String?
  createdAt      DateTime         @default(now())
  auditLogs      AuditLog[]
  checkIns       CheckIn[]        @relation("ManagerCheckIns")
  approvedSheets GoalSheet[]      @relation("Approver")
  goalSheets     GoalSheet[]      @relation("EmployeeSheets")
  sharedPushes   SharedGoalPush[]
  manager        User?            @relation("ReportsTo", fields: [managerId], references: [id])
  directReports  User[]           @relation("ReportsTo")
}

model PerformanceCycle {
  id          String     @id @default(cuid())
  year        Int
  phase       CyclePhase
  windowStart DateTime
  windowEnd   DateTime
  isActive    Boolean    @default(true)
}

model GoalSheet {
  id           String          @id @default(cuid())
  employeeId   String
  year         Int             @default(2026)
  status       GoalSheetStatus @default(DRAFT)
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?
  lockedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  checkIns     CheckIn[]
  goals        Goal[]
  approvedBy   User?           @relation("Approver", fields: [approvedById], references: [id])
  employee     User            @relation("EmployeeSheets", fields: [employeeId], references: [id])

  @@unique([employeeId, year])
}

model Goal {
  id                String         @id @default(cuid())
  goalSheetId       String
  thrustArea        String
  title             String
  description       String?
  uomType           UomType
  target            String
  weightage         Float
  isShared          Boolean        @default(false)
  sharedGroupId     String?
  isPrimaryOwner    Boolean        @default(true)
  actualAchievement String?
  deadline          DateTime?
  completionDate    DateTime?
  progressStatus    ProgressStatus @default(NOT_STARTED)
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  goalSheet         GoalSheet      @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
}

model SharedGoalPush {
  id            String   @id @default(cuid())
  title         String
  description   String?
  thrustArea    String
  uomType       UomType
  target        String
  pushedById    String
  sharedGroupId String   @unique
  createdAt     DateTime @default(now())
  pushedBy      User     @relation(fields: [pushedById], references: [id])
}

model CheckIn {
  id                  String     @id @default(cuid())
  goalSheetId         String
  quarter             CyclePhase
  managerComment      String?
  managerId           String?
  employeeCompletedAt DateTime?
  managerCompletedAt  DateTime?
  createdAt           DateTime   @default(now())
  manager             User?      @relation("ManagerCheckIns", fields: [managerId], references: [id])
  goalSheet           GoalSheet  @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)

  @@unique([goalSheetId, quarter])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  field      String
  oldValue   String?
  newValue   String?
  userId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalSheetStatus {
  DRAFT
  SUBMITTED
  RETURNED
  APPROVED
}

enum UomType {
  NUMERIC_MIN
  NUMERIC_MAX
  PERCENT_MIN
  PERCENT_MAX
  TIMELINE
  ZERO_BASED
}

enum ProgressStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum CyclePhase {
  GOAL_SETTING
  Q1_CHECKIN
  Q2_CHECKIN
  Q3_CHECKIN
  Q4_CHECKIN
}
